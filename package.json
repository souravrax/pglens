{
  "name": "pgviz-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for pgviz — a VS Code extension for visualizing PostgreSQL schemas as ER diagrams",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter pgviz watch",
    "build": "pnpm --filter pgviz build",
    "build:landing": "pnpm --filter landing build",
    "typecheck": "pnpm --filter pgviz lint",
    "lint": "pnpm --filter pgviz lint",
    "format": "prettier --write ."
  }
}
