---
const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    description: 'For solo developers exploring PostgreSQL.',
    features: [
      'Full schema visualization',
      'Visual EXPLAIN breakdowns',
      'Query explorer & SQL editor',
      'All data stays local (OS Keyring)',
      'Community support',
    ],
    cta: 'Download Free',
    href: 'https://github.com/souravrax/pgviz/releases',
    highlighted: false,
    tabs: null,
  },
  {
    name: 'Pro',
    description: 'For power users & independent devs.',
    features: [
      'Everything in Free',
      '2 device activations',
      'Cloud / local sync for queries & connections',
      'Access to all upcoming Pro features',
    ],
    cta: 'Get Pro',
    highlighted: true,
    tabs: [
      { label: 'Monthly', price: '$4', period: '/mo' },
      { label: 'Yearly', price: '$24', period: '/yr', badge: 'Save 50%' },
      { label: 'Lifetime', price: '$59', period: 'once', badge: 'Best value' },
    ],
  },
  {
    name: 'Team',
    description: 'For organizations & engineering squads.',
    features: [
      'Everything in Pro',
      '5 device activations per license key',
      'Secure team connection profile sharing',
      'Priority support & issue triage',
      'Team collaboration workspaces',
    ],
    cta: 'Get Team',
    highlighted: false,
    tabs: [
      { label: 'Monthly', price: '$9', period: '/mo' },
      { label: 'Yearly', price: '$49', period: '/yr', badge: 'Save 55%' },
    ],
  },
];
---

<section class="py-16 sm:py-20" id="pricing">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-12 sm:gap-16">
      <div class="flex flex-col gap-4">
        <h2 class="text-3xl font-medium tracking-tight sm:text-4xl">Pricing</h2>
        <p class="text-primary-950/70 dark:text-primary-200/70 text-lg">
          Free for personal use. Upgrade when you need multi-device sync or team collaboration.
        </p>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        {
          tiers.map((tier) => (
            <div
              class:list={[
                'flex flex-col gap-8 rounded-3xl px-6 py-8',
                tier.highlighted
                  ? 'bg-primary-600 text-white dark:bg-primary-500'
                  : 'bg-primary-500/10 dark:bg-primary-400/10',
              ]}
              x-data={`{ activeTab: '${tier.tabs ? tier.tabs[1].label : ''}' }`}
            >
              <div class="flex flex-col gap-4">
                <h3 class:list={['text-xl font-medium', tier.highlighted && 'text-white']}>
                  {tier.name}
                </h3>

                {tier.tabs ? (
                  <div class="flex flex-col gap-4">
                    {/* Tab buttons */}
                    <div
                      class:list={[
                        'inline-flex rounded-full p-1',
                        tier.highlighted
                          ? 'bg-white/20'
                          : 'bg-primary-600/10 dark:bg-primary-400/10',
                      ]}
                    >
                      {tier.tabs.map((tab) => (
                        <button
                          type="button"
                          class:list={[
                            'flex-1 rounded-full px-3 py-1.5 text-sm font-medium transition',
                            tier.highlighted
                              ? 'text-white/70 hover:text-white'
                              : 'text-primary-950/60 hover:text-primary-950 dark:text-primary-200/60 dark:hover:text-primary-200',
                          ]}
                          :class={`
                            ${tier.highlighted ? 'bg-white text-primary-600 shadow-sm' : 'bg-white text-primary-700 dark:bg-primary-950 dark:text-primary-300 shadow-sm'}
                          `}
                          x-bind:class={`activeTab === '${tab.label}' ? '${tier.highlighted ? 'bg-white text-primary-600 shadow-sm' : 'bg-white text-primary-700 dark:bg-primary-950 dark:text-primary-300 shadow-sm'}' : ''`}
                          x-on:click={`activeTab = '${tab.label}'`}
                        >
                          {tab.label}
                        </button>
                      ))}
                    </div>

                    {/* Tab content */}
                    {tier.tabs.map((tab) => (
                      <div
                        x-show={`activeTab === '${tab.label}'`}
                        x-transition
                        class="flex flex-col gap-1"
                      >
                        <div class="flex items-baseline gap-2">
                          <span class:list={['text-4xl font-bold', tier.highlighted && 'text-white']}>
                            {tab.price}
                          </span>
                          <span
                            class:list={[
                              'text-sm',
                              tier.highlighted
                                ? 'text-white/80'
                                : 'text-primary-950/60 dark:text-primary-200/60',
                            ]}
                          >
                            {tab.period}
                          </span>
                          {tab.badge && (
                            <span
                              class:list={[
                                'ml-auto text-xs font-bold px-2 py-0.5 rounded-full',
                                tier.highlighted
                                  ? 'bg-white/20 text-white'
                                  : 'bg-primary-600/10 text-primary-700 dark:bg-primary-400/20 dark:text-primary-300',
                              ]}
                            >
                              {tab.badge}
                            </span>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="flex items-baseline gap-1">
                    <span class:list={['text-4xl font-bold', tier.highlighted && 'text-white']}>
                      {tier.price}
                    </span>
                    <span
                      class:list={[
                        'text-sm',
                        tier.highlighted
                          ? 'text-white/80'
                          : 'text-primary-950/60 dark:text-primary-200/60',
                      ]}
                    >
                      {tier.period}
                    </span>
                  </div>
                )}

                <p
                  class:list={[
                    'text-sm',
                    tier.highlighted
                      ? 'text-white/80'
                      : 'text-primary-950/60 dark:text-primary-200/60',
                  ]}
                >
                  {tier.description}
                </p>
              </div>

              <ul class="flex flex-col gap-3">
                {tier.features.map((feature) => (
                  <li class="flex items-center gap-3 text-sm">
                    <svg
                      class:list={[
                        'h-5 w-5 shrink-0',
                        tier.highlighted ? 'text-white' : 'text-primary-600 dark:text-primary-400',
                      ]}
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M9.9997 15.1709L19.1921 5.97852L20.6063 7.39273L9.9997 17.9993L3.63574 11.6354L5.04996 10.2212L9.9997 15.1709Z" />
                    </svg>
                    <span class:list={[tier.highlighted ? 'text-white/90' : '']}>{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href="https://pgviz.lemonsqueezy.com/checkout"
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  'mt-auto inline-flex items-center justify-center rounded-full px-5 py-3 text-base font-medium transition',
                  tier.highlighted
                    ? 'bg-white text-primary-600 hover:bg-primary-50'
                    : 'bg-primary-600 text-white hover:bg-primary-700 dark:bg-primary-400 dark:text-primary-950 dark:hover:bg-primary-300',
                ]}
              >
                {tier.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
